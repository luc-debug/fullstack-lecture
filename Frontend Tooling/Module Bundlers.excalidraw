      "versionNonce": 634735822,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774965822007,
      "link": null,
      "locked": false,
      "text": "Analyzes modules/dependencies \nand combines into optimized \noutput (a single file or a bundle)\n",
      "fontSize": 14.773039156404845,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Analyzes modules/dependencies \nand combines into optimized \noutput (a single file or a bundle)\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dFkAJBBB9q7WsS-fNUTy-",
      "type": "text",
      "x": -6268.558847219228,
      "y": -13592.648936961863,
      "width": 292.34933991718526,
      "height": 69.87217182567412,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bme",
      "roundness": null,
      "seed": 1903473042,
      "version": 2674,
      "versionNonce": 1981212242,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774965579861,
      "link": null,
      "locked": false,
      "text": "Transforms source code from one syntax\nto another.\nCommonly called compilers, but they are\ntechnically transpillers.",
      "fontSize": 13.974434365134824,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Transforms source code from one syntax to another.\nCommonly called compilers, but they are technically transpillers.",
      "autoResize": false,
      "lineHeight": 1.25
    },
